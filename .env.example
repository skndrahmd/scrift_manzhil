# ============================================
# Greens Three BMS - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control!

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# TWILIO CONFIGURATION
# ============================================
# Get these from: https://console.twilio.com/

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# ============================================
# APP URL
# ============================================
# Your deployed application URL (no trailing slash)

NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ============================================
# TWILIO WHATSAPP TEMPLATE SIDs
# ============================================
# Create these templates in Twilio Console:
# https://console.twilio.com/us1/develop/sms/content-template-builder
# Format: HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Welcome Message
TWILIO_WELCOME_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Booking Templates
TWILIO_BOOKING_PAYMENT_CONFIRMED_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_BOOKING_PAYMENT_REMINDER_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_BOOKING_CANCELLED_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Complaint Templates (Resident Notifications)
TWILIO_COMPLAINT_REGISTERED_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_COMPLAINT_IN_PROGRESS_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_COMPLAINT_COMPLETED_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_COMPLAINT_REJECTED_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Maintenance Templates
TWILIO_MAINTENANCE_INVOICE_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_MAINTENANCE_PAYMENT_REMINDER_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_MAINTENANCE_PAYMENT_CONFIRMED_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Account Management Templates
TWILIO_ACCOUNT_BLOCKED_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_ACCOUNT_REACTIVATED_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin Notification Templates
TWILIO_NEW_COMPLAINT_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PENDING_COMPLAINT_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_DAILY_REPORT_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Broadcast Templates
TWILIO_BROADCAST_ANNOUNCEMENT_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
